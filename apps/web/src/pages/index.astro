---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import ProjectCard from '../components/ProjectCard.astro';
import { featuredProjects } from '../data/projects';

const stagger = (index: number) => ({
  style: `animation-delay: ${index * 0.2}s`,
});
---

<Layout>
  <header class="opacity-0 animate-fade-in-up" {...stagger(0)}>
    <h1 class="text-primary text-xl font-bold">Haadi</h1>
    <p class="text-muted text-sm mb-6">frontend developer. 20. unskilled.</p>
    <p>
      hey. i&apos;m haadi. a frontend-forward fullstack developer who enjoys the
      art of software engineering. i&apos;m open to collaborate on any projects
      you might have in mind. feel free to reach out.
    </p>
  </header>

  <div class="opacity-0 animate-fade-in-up flex flex-col gap-2.5 pt-6" {...stagger(2)}>
    <h5 class="text-secondary font-medium">what i do</h5>
    <ul class="list-inside list-disc [&>li]:leading-loose">
      <li>build web & mobile apps</li>
      <li>obsess over AI</li>
      <li>read code and docs (a lot)</li>
      <li>refactore for fun</li>
    </ul>
  </div>

  <div class="opacity-0 animate-fade-in-up flex flex-col gap-2.5 pt-6" {...stagger(3)}>
    <h5 class="text-secondary font-medium">what i work with</h5>
    <ul class="list-inside list-disc [&>li]:leading-loose">
      <li>react</li>
      <li>nextjs</li>
      <li>tanstack start</li>
      <li>astro</li>
      <li>drizzle + sql</li>
      <li>convex</li>
    </ul>
  </div>

  <div
    class="opacity-0 animate-fade-in-up flex w-full flex-col gap-4 pt-6"
    {...stagger(4)}
  >
    <h5 class="text-secondary font-medium">projects</h5>
    {
      featuredProjects.map((project, index) => (
        <ProjectCard {...project} />
      ))
    }
    <p class="text-muted pt-2 text-sm">
      interested in other things i&apos;ve worked on?
      <a
        href="/projects"
        class="group text-secondary hover:text-primary inline-flex items-center gap-1 transition-colors"
      >
        check them out <Icon
          name="arrow-right"
          class="size-3.5 opacity-0 transition-all duration-200 group-hover:translate-x-0.5 group-hover:opacity-100"
        />
      </a>
    </p>
  </div>

  <nav class="opacity-0 animate-fade-in-up flex gap-4 pt-6" {...stagger(5)}>
    <a
      href="/blog"
      class="group text-secondary hover:text-primary inline-flex items-center gap-1 transition-colors"
      >blog <Icon
        name="arrow-right"
        class="size-4 opacity-0 transition-all duration-200 group-hover:translate-x-0.5 group-hover:opacity-100"
      /></a
    >
  </nav>
</Layout>
