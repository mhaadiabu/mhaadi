---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import ProjectCard from "../components/ProjectCard.astro";
import { featuredProjects } from "../data/projects";
---

<Layout>
  <header class='mb-6'>
    <h1 class='text-xl font-bold text-(--color-primary)'>Haadi</h1>
    <p class='text-sm text-(--color-text-muted)'>frontend developer. 20. unskilled.</p>
  </header>

  <p>hey there. i&apos;m haadi, a wannabe fullstack dev who builds nothing for fun. willing to collaborate on whatever you have for me regardless. don&apos;t hesitate to hmu.</p>

  <div class='flex flex-col gap-2.5 pt-6'>
    <h5 class='font-medium text-(--color-secondary)'>what i do</h5>
    <ul class='list-disc list-inside [&>li]:leading-loose'>
      <li>build web apps</li>
      <li>build mobile apps (if you're willing to pay what i ask)</li>
      <li>read code and docs (a lot)</li>
      <li>pretend to build while you watching</li>
    </ul>
  </div>

  <div class='flex flex-col gap-4 pt-6 w-full'>
    <h5 class='font-medium text-(--color-secondary)'>projects</h5>
    {featuredProjects.map((project) => (
      <ProjectCard {...project} />
    ))}
    <p class='text-sm text-(--color-text-muted) pt-2'>
      brave enough to witness the rest of this mess?
      <a href='/projects' class='group inline-flex items-center gap-1 text-(--color-secondary) hover:text-(--color-primary) transition-colors'>
        view all <Icon name='arrow-right' class='size-3.5 opacity-0 group-hover:opacity-100 transition-all duration-200 group-hover:translate-x-0.5' />
      </a>
    </p>
  </div>

  <nav class='flex gap-4 pt-6'>
    <a href='/blog' class='group inline-flex items-center gap-1 text-(--color-secondary) hover:text-(--color-primary) transition-colors'>blog <Icon name='arrow-right' class='size-4 opacity-0 group-hover:opacity-100 transition-all duration-200 group-hover:translate-x-0.5' /></a>
  </nav>
</Layout>
