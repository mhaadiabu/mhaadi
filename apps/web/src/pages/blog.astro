---
import Layout from "../layouts/Layout.astro";

const stagger = (index: number) => ({
  style: `animation-delay: ${index * 1.5}s`,
});
---

<Layout
  title="blog"
  description="i'm not smart. but i think a lot. though my thoughts are almost never complete. i dump them here when they are. enjoy (or don't)."
>
  <p class="text-primary animate-fade-in-up text-lg font-bold" {...stagger(0)}>
    writing...
  </p>
</Layout>
