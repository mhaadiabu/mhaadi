---
import '../styles/global.css';

import {ClientRouter} from 'astro:transitions';

import Layout from '../layouts/Layout.astro'
import Footer from '../components/Footer.astro';
---

<html class='dark'>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" href="/assets/fonts/PaperMono-Regular.ttf" as="font" type="font/ttf" crossorigin />
    <meta name="generator" content={Astro.generator} />
    <title>404</title>

    <ClientRouter />
  </head>
  <body class='h-screen bg-black text-neutral-400 container w-full max-w-5xl mx-auto font-paper-mono text-sm' transition:animate='slide'>
    <main class='flex flex-col w-full max-w-3xl m-auto justify-center items-center text-center px-4 h-full'>
      <span class='text-8xl font-bold text-red-100 mb-2.5 text-center'>404</span>

      <p className='text-neutral-600'>nothing to see here.</p>

      <a href='/' class='hover:text-neutral-100 transition-colors duration-200 text-sm'>go back home</a>
    </main>
    <Footer />
  </body>
</html>
