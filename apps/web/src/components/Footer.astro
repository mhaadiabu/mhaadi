---
import { Icon } from 'astro-icon/components';

const socials = [
  {
    label: 'github',
    href: 'https://github.com/mhaadiabu',
    icon: 'github-logo'
  },
  {
    label: 'twitter',
    href: 'https://x.com/mhaadiabu',
    icon: 'x-logo'
  },
  {
    label: 'instagram',
    href: 'https://instagram.com/mhaadiabu',
    icon: 'instagram-logo'
  },
  {
    label: 'linkedin',
    href: 'https://instagram.com/mhaadiabu',
    icon: 'linkedin-logo'
  }
]
---

<footer class='flex flex-row gap-3 items-center bottom-0 relative mt-6 mb-0 mx-auto w-full justify-center text-center'>
  {socials.map(({ label, href, icon }) => (
    <a key={label} href={href} rel='noopener noreferrer' target='_blank' class='hover:text-neutral-200 transition-colors duration-200'>
      <Icon name={icon} class='size-5.5' />
    </a>
    <p class='sr-only'>{label} link</p>
  ))}
</footer>
