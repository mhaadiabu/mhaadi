---
import { Icon } from "astro-icon/components";

const socials = [
  {
    label: "github",
    href: "https://github.com/mhaadiabu",
    icon: "github-logo",
  },
  {
    label: "twitter",
    href: "https://x.com/mhaadiabu",
    icon: "x-logo",
  },
  {
    label: "instagram",
    href: "https://instagram.com/mhaadiabu",
    icon: "instagram-logo",
  },
  {
    label: "linkedin",
    href: "https://linkedin.com/in/mohammed-haadi-abubakar-82770927a",
    icon: "linkedin-logo",
  },
];
---

<footer
  class="border-muted/25 mt-auto flex w-full flex-row items-center justify-center gap-3 border-t pt-4"
>
  {
    socials.map(({ label, href, icon }) => (
      <a
        href={href}
        rel="noopener noreferrer"
        target="_blank"
        class="hover:text-primary transition-colors duration-200"
      >
        <Icon name={icon} class="size-5.5" />
        <span class="sr-only">{label} link</span>
      </a>
    ))
  }
</footer>
