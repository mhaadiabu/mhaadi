---
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  description: string;
  image: string;
  stack: string[];
  href?: string;
  github?: string;
  disabled?: boolean;
}

const { title, description, image, stack, href, github, disabled = false } = Astro.props;
---

<article class:list={['group flex flex-col gap-3 p-4 w-full border border-border bg-bg-secondary/50 transition-all duration-300', disabled ? 'opacity-50 cursor-not-allowed' : 'hover:border-secondary hover:bg-bg-secondary']}>
  <div class='relative overflow-hidden aspect-video'>
    <img
      src={image}
      alt={title}
      class:list={['w-full h-full object-cover transition-transform duration-300', !disabled && 'group-hover:scale-105', disabled && 'blur-sm']}
    />
    {disabled && (
      <div class='absolute inset-0 flex items-center justify-center bg-bg-secondary/70'>
        <span class='text-xs font-medium text-text-muted uppercase tracking-wider px-2 py-1 border border-border bg-bg-secondary'>Coming Soon</span>
      </div>
    )}
  </div>

  <div class='flex flex-col gap-2'>
    <div class='flex items-center justify-between'>
      <h3 class='text-base font-medium text-primary'>{title}</h3>
      <div class='flex gap-2'>
        {github && !disabled && (
          <a
            href={github}
            target='_blank'
            rel='noopener noreferrer'
            class='text-text-muted hover:text-primary transition-colors duration-200'
          >
            <Icon name='github-logo' class='size-4' />
            <span class='sr-only'>GitHub repository</span>
          </a>
        )}
        {href && !disabled && (
          <a
            href={href}
            target='_blank'
            rel='noopener noreferrer'
            class='group/link text-text-muted hover:text-primary transition-colors duration-200'
          >
            <Icon name='arrow-top-right' class='size-4 transition-transform duration-200 group-hover/link:-translate-y-0.5 group-hover/link:translate-x-0.5' />
            <span class='sr-only'>View project</span>
          </a>
        )}
      </div>
    </div>

    <p class='text-sm text-text-muted line-clamp-2'>{description}</p>

    <div class='flex flex-wrap gap-2 pt-1'>
      {stack.map((tech) => (
        <div class='flex items-center gap-1.5 text-secondary hover:text-primary transition-colors duration-200' title={tech}>
          <Icon name={tech} class='size-4' />
        </div>
      ))}
    </div>
  </div>
</article>
