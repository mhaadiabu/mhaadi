---
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  description: string;
  image: string;
  stack: string[];
  href?: string;
  github?: string;
  disabled?: boolean;
}

const {
  title,
  description,
  image,
  stack,
  href,
  github,
  disabled = false,
} = Astro.props;
---

<article
  class:list={[
    'group border-border bg-bg-secondary/50 flex w-full flex-col gap-3 border p-4 transition-all duration-300',
    disabled
      ? 'cursor-not-allowed opacity-50'
      : 'hover:border-secondary hover:bg-bg-secondary',
  ]}
>
  <div class="relative aspect-video overflow-hidden">
    <img
      src={image}
      alt={title}
      class:list={[
        'h-full w-full object-cover transition-transform duration-300',
        !disabled && 'group-hover:scale-105',
        disabled && 'blur-sm',
      ]}
    />
    {
      disabled && (
        <div class="bg-bg-secondary/70 absolute inset-0 flex items-center justify-center">
          <span class="text-muted border-border bg-bg-secondary border px-2 py-1 text-xs font-medium tracking-wider uppercase">
            Coming Soon
          </span>
        </div>
      )
    }
  </div>

  <div class="flex flex-col gap-2">
    <div class="flex items-center justify-between">
      <h3 class="text-primary text-base font-medium">{title}</h3>
      <div class="flex gap-2">
        {
          github && !disabled && (
            <a
              href={github}
              target="_blank"
              rel="noopener noreferrer"
              class="text-muted hover:text-primary transition-colors duration-200"
            >
              <Icon name="github-logo" class="size-4" />
              <span class="sr-only">GitHub repository</span>
            </a>
          )
        }
        {
          href && !disabled && (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              class="group/link text-muted hover:text-primary transition-colors duration-200"
            >
              <Icon
                name="arrow-top-right"
                class="size-4 transition-transform duration-200 group-hover/link:translate-x-0.5 group-hover/link:-translate-y-0.5"
              />
              <span class="sr-only">View project</span>
            </a>
          )
        }
      </div>
    </div>

    <p class="text-muted line-clamp-2 text-sm">{description}</p>

    <div class="flex flex-wrap gap-2 pt-1">
      {
        stack.map((tech) => (
          <div
            class="text-secondary hover:text-primary flex items-center gap-1.5 transition-colors duration-200"
            title={tech}
          >
            <Icon name={tech} class="size-4" />
          </div>
        ))
      }
    </div>
  </div>
</article>
