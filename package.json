{
  "name": "portfolio",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "check": "oxlint && bun run format",
    "format": "bun run --cwd apps/web format",
    "deploy": "cd apps/web && bun run deploy",
    "lint": "turbo lint",
    "fmt": "turbo format"
  },
  "dependencies": {
    "@portfolio/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@portfolio/config": "workspace:*",
    "oxlint": "^1.41.0",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.10"
}
